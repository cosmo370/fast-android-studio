{
  "name": "fast-android-studio",
  "version": "0.1.1",
  "private": true,
  "productName": "Fast Android Studio",
  "author": "ResearchLink",
  "description": "A lightweight one-click Android development console for web and Capacitor projects",
  "main": "main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "tsc --noEmit && vite build",
    "package:win": "npm run build && node scripts/package-win.cjs",
    "test": "node --test tests/*.test.cjs",
    "start": "electron ."
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.3",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "9.2.4",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.cosmo370.fastandroidstudio",
    "artifactName": "Fast-Android-Studio-Setup-${version}.${ext}",
    "asar": true,
    "directories": {
      "output": "packages"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "package.json",
      "!**/*.map"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fast Android Studio",
      "uninstallDisplayName": "Fast Android Studio"
    }
  }
}
